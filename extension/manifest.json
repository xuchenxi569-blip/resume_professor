{
  "manifest_version": 3,
  "name": "简历专家 · 岗位采集",
  "version": "0.1.0",
  "description": "自动识别招聘网页岗位信息，保存到简历专家「目标岗位库」。",
  "permissions": ["storage", "activeTab", "contextMenus", "scripting", "tabs"],
  "host_permissions": [
    "https://www.zhipin.com/*",
    "https://www.liepin.com/*",
    "https://www.linkedin.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "保存到简历专家",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.zhipin.com/*",
        "https://www.liepin.com/*",
        "https://www.linkedin.com/jobs/*"
      ],
      "js": [
        "shared/constants.js",
        "content/adapters/boss.js",
        "content/adapters/liepin.js",
        "content/adapters/linkedin.js",
        "content/adapters/generic.js",
        "content/content.js"
      ],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*"],
      "js": ["shared/constants.js", "bridge/bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
