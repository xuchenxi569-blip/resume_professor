# DeepSeek API（在 https://platform.deepseek.com 创建）
# 复制本文件为 .env.local 后填入真实密钥，切勿将 .env.local 提交到 Git
DEEPSEEK_API_KEY=sk-your-key-here

# 可选：默认 https://api.deepseek.com
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# 可选：deepseek-chat（通用）或 deepseek-reasoner（更强推理，更慢更贵）
# 若账号已开通 V4，也可试 deepseek-v4-flash / deepseek-v4-pro
DEEPSEEK_MODEL=deepseek-chat

# 强制使用本地 Mock（不调大模型）
# AI_FORCE_MOCK=true
